<!DOCTYPE html>
<html lang="rw">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kigali Cypher 250 - Impano z'Abahanzi Nyarwanda</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header>
        <div class="logo-container">
            <img src="/images/logo.jpg" alt="Kigali Cypher 250 Logo">
        </div>
        <h1>KIGALI CYPHER 250</h1>
        <p>Urubuga ruter'inkunga no kugaragaza impano z'abahanzi Nyarwanda 🇷🇼</p>
    </header>

    <main>
        <section class="intro">
            <h2>Murakaza neza ku mbuga y'abanyempano!</h2>
            <p>Hano niho hantu honyine ubonera indirimbo, amashusho n'amateka y'abahanzi bari kuzamuka neza mu Rwanda.</p>
        </section>

        <section class="artists-grid">
            <h2>Abahanzi Bagaragaza Ubuhanga</h2>
            <div class="grid">
                <% artists.forEach(artist => { %>
                    <div class="card">
                        <h3><%= artist.name %></h3>
                        <span class="genre"><%= artist.genre %></span>
                        <p><%= artist.bio %></p>
                        <button onclick="alert('Murakoze gushyigikira <%= artist.name %>!')">Sura Umuhanzi</button>
                    </div>
                <% }) %>
            </div>
        </section>
    </main>

    <footer>
        <p>&copy; 2026 Kigali Cypher 250. Uburenganzira bwose burarengewe.</p>
    </footer>
</body>
</html>