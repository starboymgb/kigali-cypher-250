<!DOCTYPE html>
<html lang="rw">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kigali Cypher 250 - Artist Platform</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="main-container">
        <!-- IGIKORA CY'IBUMOSO (CY'UMUKARA) -->
        <section class="content-area">
            <header class="top-nav">
                <div class="logo-container">
                    <img src="/images/logo.jpg" alt="Kigali Cypher 250 Logo">
                    <span class="logo-text">ZONAR (KC250)</span>
                </div>
                <div class="contact-info">
                    <span>01. CALL +250 787 654 3232</span>
                    <span>02. WRITE INFO@KC250.COM</span>
                </div>
                <div class="menu-icon">☰ MENU</div>
            </header>

            <main class="hero-section">
                <div class="number-counter">01 <span class="total">/04</span></div>
                <div class="artist-highlight">
                    <p class="welcome-text">WELCOME TO MY CYPHER</p>
                    <h1>BRUCE MELODIE - <br> <span class="orange-text">AFROBEAT KING</span> <br> FROM RWANDA</h1>
                    <p class="bio-text">Umwami w'injyana ya Afrobeat mu Rwanda, ufite amateka y'indirimbo z'ibihe byose.</p>
                    <div class="portfolio-btn">MY PORTFOLIO</div>
                </div>
                <div class="big-number">01</div>
            </main>

            <footer class="footer-nav">
                <div class="social-links">F T IG</div>
                <div class="start-explore">START EXPLORE</div>
            </footer>
        </section>

        <!-- IGIKORA CY'IBURYO (CY'ICUNGA) -->
        <aside class="sidebar-area">
            <div class="sidebar-content">
                <div class="slider-tag">HOME SLIDER</div>
                <div class="interactive-circle">
                    <div class="outer-ring"></div>
                    <div class="inner-dot"></div>
                    <div class="play-pause-btn">||</div>
                </div>
            </div>
        </aside>
    </div>
</body>
</html>